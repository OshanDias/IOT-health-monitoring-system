<body>
    <div class="container">
        <div class="header">
            <h1>💊 Smart Health Monitor</h1>
            <p>NIBM HDSE Batch 25.2 - Real-time Patient Monitoring</p>
        </div>
        
        <div id="offline-banner" class="offline" style="display: none;">
            ⚠️ No connection to Firebase - Check internet connection
        </div>
        
        <div id="status-banner" class="status-banner status-normal">
            <h2>Status: <span id="status-text">Loading...</span></h2>
            <p id="last-update">Last updated: Never</p>
        </div>
        
        <div class="cards">
            <div class="card card-normal" id="card-hr">
                <div class="card-icon">❤️</div>
                <div class="card-title">Heart Rate</div>
                <div class="card-value" id="hr-value">--</div>
                <div class="card-unit">bpm</div>
            </div>
            
            <div class="card card-normal" id="card-spo2">
                <div class="card-icon">🫁</div>
                <div class="card-title">Blood Oxygen (SpO2)</div>
                <div class="card-value" id="spo2-value">--</div>
                <div class="card-unit">%</div>
            </div>
            
            <div class="card card-normal" id="card-temp">
                <div class="card-icon">🌡️</div>
                <div class="card-title">Body Temperature</div>
                <div class="card-value" id="temp-value">--</div>
                <div class="card-unit">°C</div>
            </div>
        </div>
        
        <div class="history">
            <h2>📊 Recent Readings</h2>
            <div id="history-list">
                <p style="color: #999; text-align: center;">No data yet...</p>
            </div>
        </div>
    </div>

    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>

    <script>
        // ========== FIREBASE CONFIG ==========
        const firebaseConfig = {
            databaseURL: "https://health-monitor-iot-c3835-default-rtdb.asia-southeast1.firebasedatabase.app"
        };

        // Initialize Firebase
        firebase.initializeApp(firebaseConfig);
        const database = firebase.database();

        // ========== THRESHOLDS ==========
        const limits = {
            hr_min: 50,
            hr_max: 110,
            hr_critical_min: 40,
            hr_critical_max: 130,
            spo2_min: 92,
            spo2_critical: 90,
            temp_min: 36.0,
            temp_max: 37.5,
            temp_critical_min: 35.0,
            temp_critical_max: 39.5
        };

        // ========== LISTEN TO LATEST DATA ==========
        const vitalsRef = database.ref('/patients/patient_001/vitals');

        vitalsRef.limitToLast(1).on('child_added', (snapshot) => {
            const data = snapshot.val();
            updateDashboard(data);
            hideOfflineBanner();
        });

        vitalsRef.limitToLast(10).on('value', (snapshot) => {
            updateHistory(snapshot);
        });

        // ========== UPDATE DASHBOARD ==========
        function updateDashboard(data) {
            const hr = data.hr || 0;
            const spo2 = data.spo2 || 0;
            const temp = data.temp || 0;
            const status = data.status || 'unknown';

            // Update values
            document.getElementById('hr-value').textContent = hr > 0 ? Math.round(hr) : '--';
            document.getElementById('spo2-value').textContent = spo2 > 0 ? Math.round(spo2) : '--';
            document.getElementById('temp-value').textContent = temp > 0 ? temp.toFixed(1) : '--';

            // Update status
            const statusText = status.charAt(0).toUpperCase() + status.slice(1);
            document.getElementById('status-text').textContent = statusText;
            
            const statusBanner = document.getElementById('status-banner');
            statusBanner.className = 'status-banner status-' + status;

            // Update last update time
            const now = new Date();
            document.getElementById('last-update').textContent = 
                'Last updated: ' + now.toLocaleTimeString();

            // Color cards based on thresholds
            updateCardColor('card-hr', hr, 
                limits.hr_critical_min, limits.hr_critical_max,
                limits.hr_min, limits.hr_max);
            
            updateCardColor('card-spo2', spo2,
                limits.spo2_critical, 100,
                limits.spo2_min, 100);
            
            updateCardColor('card-temp', temp,
                limits.temp_critical_min, limits.temp_critical_max,
                limits.temp_min, limits.temp_max);
        }

        // ========== UPDATE CARD COLOR ==========
        function updateCardColor(cardId, value, critMin, critMax, warnMin, warnMax) {
            const card = document.getElementById(cardId);
            
            if (value === 0) {
                card.className = 'card card-normal';
            } else if (value < critMin || value > critMax) {
                card.className = 'card card-critical';
            } else if (value < warnMin || value > warnMax) {
                card.className = 'card card-warning';
            } else {
                card.className = 'card card-normal';
            }
        }

        // ========== UPDATE HISTORY ==========
        function updateHistory(snapshot) {
            const historyList = document.getElementById('history-list');
            historyList.innerHTML = '';

            const readings = [];
            snapshot.forEach((child) => {
                readings.push({
                    timestamp: child.key,
                    data: child.val()
                });
            });

            readings.reverse().forEach((reading) => {
                const time = new Date(reading.timestamp * 1000);
                const item = document.createElement('div');
                item.className = 'history-item';
                item.innerHTML = `
                    <div>
                        <strong>${reading.data.status.toUpperCase()}</strong><br>
                        HR: ${Math.round(reading.data.hr)} bpm | 
                        SpO2: ${Math.round(reading.data.spo2)}% | 
                        Temp: ${reading.data.temp.toFixed(1)}°C
                    </div>
                    <div class="timestamp">${time.toLocaleString()}</div>
                `;
                historyList.appendChild(item);
            });
        }

        // ========== OFFLINE DETECTION ==========
        function showOfflineBanner() {
            document.getElementById('offline-banner').style.display = 'block';
        }

        function hideOfflineBanner() {
            document.getElementById('offline-banner').style.display = 'none';
        }

        // Check connection
        const connectedRef = database.ref('.info/connected');
        connectedRef.on('value', (snap) => {
            if (snap.val() === true) {
                hideOfflineBanner();
            } else {
                showOfflineBanner();
            }
        });
    </script>
</body>
